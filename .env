# =========================
# Clash for Linux - Env Config
# =========================
# 说明：
# 1. 必填项：CLASH_URL（首次使用时填写）
# 2. 修改后执行：clashctl restart
# 3. CLASH_SECRET 留空时，脚本会自动生成
# =========================

# -------------------------
# 1) 订阅配置
# -------------------------

# Clash 订阅地址（首次使用必填）
# 示例：
# export CLASH_URL='https://example.com/sub?token=xxxx'
export CLASH_URL=''

# 是否自动更新订阅并重新生成运行配置
# true  = 启动 / 重启时自动拉取订阅并生成配置
# false = 不自动拉取，直接使用已有 runtime/config.yaml
export CLASH_AUTO_UPDATE='true'

# 订阅请求头（可选）
# 某些订阅源需要自定义 User-Agent 或 Authorization
# 多个请求头可用 ; 分隔
# 示例：
# export CLASH_HEADERS='User-Agent: ClashforWindows/0.20.39;Authorization: Bearer xxxxxx'
export CLASH_HEADERS='User-Agent: ClashforWindows/0.20.39'

# 当前订阅名称（可选，供多订阅管理使用）
export CLASH_SUBSCRIPTION=''

# -------------------------
# 2) Mihomo 内核
# -------------------------

# 是否自动下载内核
# auto  = 缺失时自动下载
# true  = 强制按脚本逻辑下载/校验
# false = 不自动下载，需自行准备内核
export CLASH_AUTO_DOWNLOAD='auto'

# 固定内核版本（可按项目发布节奏调整）
export MIHOMO_VERSION='v1.19.21'

# 自定义下载模板（可选）
# {version} 和 {arch} 会被脚本替换
export CLASH_DOWNLOAD_URL_TEMPLATE='https://github.com/MetaCubeX/mihomo/releases/download/{version}/mihomo-{arch}-{version}.gz'

# -------------------------
# 3) 控制面板 / API 安全
# -------------------------

# 控制面板密钥
# 留空时自动生成
export CLASH_SECRET=''

# 是否启用 external-controller
export EXTERNAL_CONTROLLER_ENABLED='true'

# 默认仅监听本机，更适合作为公共项目默认值
# 如需局域网 / 公网访问，再手动改为 0.0.0.0:9090
export EXTERNAL_CONTROLLER='127.0.0.1:9090'

# Dashboard 公网地址（可选）
# 留空表示不额外显示公网地址
export CLASH_DASHBOARD_PUBLIC_URL=''

# 输出 Secret 的显示策略
export CLASH_SHOW_SECRET='false'
export CLASH_SHOW_SECRET_MASKED='true'

# TLS 校验
# 默认不要关闭；仅在特殊订阅源证书异常时临时开启 true
export ALLOW_INSECURE_TLS='false'

# -------------------------
# 4) 代理监听与端口
# -------------------------

# 端口可填具体值，也可填 auto（前提是你的脚本支持自动分配）
export CLASH_HTTP_PORT='7890'
export CLASH_SOCKS_PORT='7891'
export CLASH_REDIR_PORT='7892'

# 默认仅本机监听，更安全
# 如需给局域网设备使用，再改为 0.0.0.0
export CLASH_LISTEN_IP='127.0.0.1'

# 是否允许局域网访问
# 若 CLASH_LISTEN_IP=127.0.0.1，这里即使为 true 也没有实际意义
export CLASH_ALLOW_LAN='false'

# -------------------------
# 5) 运行校验
# -------------------------

# GeoIP / 配置测试相关
export CLASH_SKIP_GEOIP_TEST_FAILURE='true'
export CLASH_CONFIG_TEST_TIMEOUT='30'

# -------------------------
# 6) Mixin 配置（可选）
# -------------------------

# 指定 mixin 目录（默认可不填）
# export CLASH_MIXIN_DIR='config/mixin.d'

# 追加多个 mixin 文件（逗号分隔）
# export CLASH_MIXIN_PATHS='config/mixin.d/base.yaml,config/mixin.d/rules.yaml'

# -------------------------
# 7) Tun 模式（可选）
# -------------------------

# export CLASH_TUN_ENABLE='false'
# export CLASH_TUN_STACK='system'
# export CLASH_TUN_AUTO_ROUTE='true'
# export CLASH_TUN_AUTO_REDIRECT='false'
# export CLASH_TUN_STRICT_ROUTE='false'
# export CLASH_TUN_DEVICE=''
# export CLASH_TUN_MTU=''
# export CLASH_TUN_DNS_HIJACK='any:53'

# -------------------------
# 8) Subconverter（可选）
# -------------------------

# 若你的环境集成了 subconverter，可在此配置
export SUBCONVERTER_URL='http://127.0.0.1:25500'
export SUBCONVERTER_READY='false'